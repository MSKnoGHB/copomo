<div class="container-fluid">
  <div class = "row">
    <div class = "col-11 text-center">
      <div class = "row">
        <div class = "col-12">
          <% if flash[:notice] %>
            <div class="alert alert-success">
              <%= flash[:notice] %>
            </div>
          <% end %>
        </div>
      </div>
      <div class = "row">
        <div class = "col-12">
          <h3 class="pt-3 pb-3 m-0">学習テーマ一覧</h3>
        </div>
      </div>
      <div class = "row">
        <div class = "col-12">
          <div class="table-responsive">
            <table class="table table-hover text-nowrap">
              <thead class="table-light">
                <tr>
                  <th class= "align-middle text-center">No.</th>
                  <th class= "align-middle">テーマ名</th>
                  <th class= "align-middle">テーマ説明</th>
                  <th class= "align-middle text-center">テーマ色</th>
                  <th class= "align-middle text-center">学習カテゴリ</th>
                  <th class= "align-middle text-center"></th>
                </tr>
              </thead>
              <tbody>
                <% @study_themes.each_with_index do |study_theme, i|%>
                  <tr>
                    <td class= "align-middle text-center"><%= i + 1 %></td>
                    <td class= "align-middle"><%= study_theme.theme_title %></td>
                    <td class= "align-middle"><%= study_theme.theme_body %></td>
                    <td class= "align-middle text-center"><%= study_theme.theme_color_i18n %></td>
                    <td class= "align-middle text-center"><%= study_theme.study_category.category_title %></td>
                    <% if @user == current_user %>
                      <td class= "align-middle text-center">
                        <%= link_to "編集", edit_public_study_theme_path(study_theme), class: "btn btn-sm btn-success" %>
                        <%= link_to "削除", public_study_theme_path(study_theme), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-danger" %>
                      </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>