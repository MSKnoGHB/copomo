<div class = "container-fluid">
  <div class = "row ">
    
    <div class = "col-12 col-md-12 col-lg-6">
      <h3>学習記録詳細</h3>
      <%= form_with model: [:public, @study_record], url: post_public_study_record_path(@study_record), method: :patch do |f| %>
      <p class = "mb-3">学習ルーム: <%= @room %></p>
      <p class = "mb-3">学習カテゴリ: <%= @study_category %></p>
      <p class = "mb-3">学習テーマ: <%= @study_theme %></p>
      <p class = "mb-3">学習開始時間: <%= @started_at %></p>
      <p class = "mb-3">学習終了時間: <%= @ended_at %></p>
      <p class = "mb-3">学習集中時間: <%= "#{@total_focus_minutes}分" %></p>
      <div>
        <%= f.label :is_publish, "タイムラインに表示する" %>
        <%= f.check_box :is_publish, checked: true %>
      </div>
        <%= f.label :record_body, "投稿内容", class: "form-label" %>
        <% if @study_record.errors.any? %>
          <% @study_record.errors.full_messages.each do |message| %>
            <p><%= message %></p>
          <% end %>
        <% end %>
        <%= f.text_area :record_body, class: "form-control mb-3", rows: 5 %>
        <%= f.submit "学習内容を投稿する", class: "btn btn-outline-success w-100 mb-3" %>
      <% end %>  
    </div>
    
    <div class = "col-12 col-md-12 col-lg-6">
      <div class = "row mr-3">
        <div class = "col-12 m-3">
          <div class = "row p-3 border bg-pale">
            <div class = "col-3 d-flex justify-content-center">
              No.
            </div>      
            <div class = "col-3 d-flex justify-content-center">
              集中開始時刻
            </div>
            <div class = "col-3 d-flex justify-content-center ">
              集中終了時刻
            </div>
            <div class = "col-3 d-flex justify-content-center ">
              集中時間
            </div>
          </div>
          <div class="row mb-3", style="height: 60vh;">
            <div class = "col-12 h-100 overflow-auto border bg-pale">
              <% @study_intervals.each.with_index(1) do |study_interval, i| %>
                <div class = "row p-3 border-bottom">
                  <div class = "col-3 d-flex justify-content-center align-items-center">
                    <p class = "mb-0"><%= i %></p>
                  </div>
                  <div class = "col-3 d-flex justify-content-center align-items-center">
                    <p class = "mb-0"><%= study_interval.started_at.strftime("%H:%M:%S") %></p>
                  </div>
                  <div class = "col-3 d-flex justify-content-center align-items-center">
                    <p class = "mb-0"><%= study_interval.ended_at.strftime("%H:%M:%S") %></p>
                  </div>
                  <div class = "col-3 d-flex justify-content-center align-items-center">
                    <p class = "mb-0"><%= ((study_interval.ended_at - study_interval.started_at)/60).to_i %>分</p>
                  </div>
                </div>
              <% end %> 
            </div>
          </div>  
        </div>
      </div>
    </div>
  </div>
</div>