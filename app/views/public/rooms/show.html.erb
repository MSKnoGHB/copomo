<!-- モーダル_テーマ選択表示 -->
<div class = "modal fade" id="entryModal" data-backdrop="static" data-bs-backdrop="static" tabindex="-1" aria-hidden="true">
  <div class = "modal-dialog modal-dialog-centered">
    <div class = "modal-content">
      <div class="container-fluid">
        <div class = "modal-header">
          <div class="row mx-auto mb-3">
            <div class="col-12">
              <h3>学習テーマ選択</h3>
            </div>
          </div>
        </div>
        <div class = "modal-body">
          <div class="row mx-auto mb-5">
            <div class="col-12">
              <%= form_with model: [:public, @room_access] do |f| %>
                <%= f.hidden_field :room_id, value: @room.id %>
                <%= f.label :theme_title, "学習テーマ名", class: "form-label  w-100 " %>
                <%= f.collection_select :study_theme_id, @study_themes, :id, :theme_title, { prompt: "学習テーマを選択" },{ required: true, class: "form-select w-100 mb-3" } %>
                <%= f.submit "入室する", class: "btn btn-outline-primary w-100" %>
              <% end %>
            </div>
          </div>
          <div class="row mx-auto">
            <div class="col-12">
              <%= form_with model: [:public, @study_theme] do |f| %>
                <%= f.hidden_field :room_id, value: @room.id %>
                <%= f.label :category_title, "学習カテゴリ", class: "form-label  w-100" %>
                <%= f.collection_select :study_category_id, @study_categories, :id, :category_title, { prompt: "学習カテゴリを選択" }, { required: true, class: "form-select w-100 mb-3" } %>
                <%= f.label :theme_color, "学習テーマ色", class: "form-label  w-100"  %>
                <%= f.select :theme_color, StudyTheme.theme_colors_i18n.invert, { include_blank: "学習テーマ色を選択"}, { required: true, class: "form-select  w-100 mb-3" }%>
                <%= f.label :theme_title, "学習テーマ名", class: "form-label  w-100" %><%= alert %>
                <%= f.text_area :theme_title, class: "form-control mb-3", rows: 1, required: true %>
                <%= f.label :theme_body, "学習テーマ説明", class: "form-label  w-100"  %>
                <%= f.text_area :theme_body, class: "form-control mb-3", rows: 1 %>
                <%= f.submit "学習内容を登録して入室する", class: "btn btn-outline-success w-100 mb-3",onclick: "if(this.form.checkValidity()){ const val = this.form.querySelector('textarea[name*=\"theme_title\"]').value.trim(); if(!val){ alert('テーマ名を空白のみで登録することはできません'); return false; } } " %>
              <% end %>
            </div>
          </div>
        </div>
        <div class = "modal-footer">
          <div class="row mx-auto">
            <div class="col-12">
              <%= link_to "学習ルーム選択に戻る", public_rooms_path, class: "btn btn-outline-secondary btn-sm" %>
            </div>
          </div>    
        </div>
      </div>
    </div>  
  </div> 
</div>  


<!-- メイン画面_学習ルーム画面 -->
<div class = "container-fluid">
  <div class = "row">
    <div class = "col-5">
      <div class = "row m-0">
        <div class = "col-12 p-0 border d-flex justify-content-center align_items-center">
          <h3 class = "mb-0 p-3" style= "font-size: 20px;"><strong>チャット</strong></h3>
        </div>
      </div>
      <div class = "row m-0">
        <div class = "col-12 p-0">
          <div class = "p-3 overflow-auto border" id = "chat-logs-container" data-room-id = "<%= @room.id %>" style="height: 500px;">
            <% @chat_logs.each do |log| %>
              <%= render "shared/chat_log", chat_log: log %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
    <div class = "col-7">
      <div class = "row">
        <div class="col-3 pt-5 pr-0 pl-0 d-flex flex-column justify-content-center align-items-center">
          <span id="mode" style="font-size: 50px;"><%= @timer[:mode] %></span>
          <span id="timer" style="font-size: 50px;"><%= @timer[:remaining] %></span>
          <% if @study_status == "waiting" %>
            <%= button_to "学習を開始", public_study_records_path(room_access_id: @active_room_access.id), method: :post, class: "btn btn-primary" %>
          <% end %>
          <% if @study_record %>
            <% if @study_status == "studying" %>
              <%= button_to "一時離席", public_study_interval_path(study_record_id: @study_record.id, room_access_id: @active_room_access.id), method: :patch, class: "btn btn-primary w-100", form_class: "w-100 mt-3" %>
            <% end %>
            <% if @study_status == "paused" %>
              <%= button_to "学習を再開", public_study_intervals_path(study_record_id: @study_record.id, room_access_id: @active_room_access.id), method: :post, class: "btn btn-primary w-100", form_class: "w-100 mt-3" %> 
            <% end %>
            <% if @study_status != "waiting" %>
              <%= link_to "学習を終了", finish_public_study_record_path(study_record_id: @study_record.id, room_access_id: @active_room_access.id), method: :patch, data: { confirm: "学習を終了し、退室します。\n本当によろしいですか？" }, class: "btn btn-outline-success w-100 m-3", form_class: "w-100" %>
            <% end %>        
          <% end %>
        </div>
        <div class="col-9 mb-3  d-flex flex-column">
          <div class = "row m-0">
            <div class = "col-12 p-0 border d-flex justify-content-center align_items-center">
              <h3 class = "mb-0 p-3" style= "font-size: 20px;"><strong>現在参加者</strong></h3>
            </div>
          </div>  
          <div class="row m-0 border" style="min-height: 400px; align-content: flex-start;">
            <div class="col-12">
              <div class="row m-0 border-bottom">
                <div class="col-5 p-1 d-flex justify-content-center">
                  ユーザー名
                </div>
                <div class="col-4 p-1 d-flex justify-content-center">
                  学習テーマ
                </div>
                <div class="col-3 p-1 d-flex justify-content-center">
                  ステータス
                </div>
              </div>
              <div id = "active-users-container">
                <%= render "shared/active_users_list", room_accesses: @room_accesses %>
              </div>
            </div>
          </div>
        </div>
      </div>
      <%= form_with model: @chat_log, url: public_chat_logs_path, local: false, html: { id: "chat-form" } do |f| %>
        <div class="row">
          <div class="col-10 pr-0 pl-0">
            <%= f.hidden_field :room_id, value: @room.id %>
            <%= f.text_area :message, class: "mb-3 form-control", id: "chat-input", rows: 3, placeholder: "チャットメッセージを入力..." %>
          </div>
          <div class="col-2">
            <%= f.hidden_field :stamp_id, id: "stamp-id" %>
            <button type = "button" class = "w-100 mb-1 btn btn-secondary" id = "stamp-btn">😊</button>
            <%= f.submit "送信", class: "w-100 btn btn-primary"%>
          </div>
        </div>
        <div class="row">
          <div class="col-12">
            <div class = "stamp-modal d-none flex-wrap justify-content-start" id = "stamp_modal">
              <% @stamps.each do |stamp|%>
                <div class = "mr-3 d-flex flex-column align-items-center">
                  <%= image_tag stamp.stamp_image, data: {id: stamp.id }, class: "stamp-item", style: "width:40px; height:40px; object-fit:cover; cursor: pointer;" %>
                  <span style = "font-size:10px;"><%= stamp.stamp_name %></span>
                </div>
              <% end%>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<% unless current_user.room_accesses.exists?( is_active: true ) %>
  <script>
    document.addEventListener('turbolinks:load', function() {
      var modalElement = document.getElementById('entryModal');

      if (modalElement) {
        var myModal = new bootstrap.Modal(modalElement, {
          backdrop: 'static',
          keyboard: false
        });
        myModal.show();
      }
    });
  </script>
<% end %>


