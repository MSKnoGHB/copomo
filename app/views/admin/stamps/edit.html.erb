<div class="container-fluid">
  <div class = "row">
    <div class = "col-11 mx-auto">
      <div class = "row mb-3", style="border-bottom: 2px solid black;">
        <div class = "col-12">
          <h3>スタンプ編集</h3>
        </div>
      </div>
      <div class = "row mb-3 d-flex align-items-center">
        <div class = "col-1 text-center">
          <p>ID</p>
        </div>
        <div class = "col-2 text-center">
          <p>スタンプ名</p>
        </div>
        <div class = "col-4 text-center">
          <p>スタンプイメージ</p>
        </div>
        <div class = "col-2 text-center">
          <p>更新日</p>
        </div>
        <div class = "col-1 text-center">
          <p>ステータス</p>
        </div>
      </div>
      <div class = "row mb-3 d-flex align-items-center">
        <div class = "col-1 text-center">
          <p><%= @stamp.id %></p>
        </div>
        <div class = "col-2 text-center">
          <p><%= @stamp.stamp_name %></p>
        </div>
        <div class = "col-4 text-center">
          <p><%= image_tag @stamp.stamp_image, width: 100 %></p>
        </div>
        <div class = "col-2 text-center">
          <p><%= @stamp.updated_at.strftime("%-m月%-d日") %>(<%= %w(日 月 火 水 木 金 土)[@stamp.updated_at.wday] %>)</p>
        </div>
        <div class = "col-1 text-center">
          <p><%= @stamp.is_active ? "有効" : "無効" %></p>
        </div>
      </div>
      <div class = "row mb-3 d-flex align-items-center">
        <div class = "col-12">
          <h3>更新フォーム</h3>
        </div>
      </div>
      <%= form_with model: [:admin, @stamp] do |f| %>
        <div class = "row mb-3 d-flex justify-content-center align-items-center">
          <div class = "col-1 text-center">
            <p class="m-0">編集</p>
          </div>
          <div class = "col-2 text-center">
            <% f.label :stamp_name %>
            <%= f.text_area :stamp_name, class: "form-control w-100", required: true %>
          </div>
          <div class = "col-4 text-center">
            <% f.label :stamp_image %>
            <%= f.file_field :stamp_image, accept:"image/*", required: true %>
          </div>
          <div class = "col-2 text-center">
            <%= Time.current.strftime("%-m月%-d日") %>(<%= %w(日 月 火 水 木 金 土)[Time.current.wday] %>)
          </div>
          <div class = "col-1 text-center">
            <% f.label :is_active %>
            <%= f.radio_button :is_active, true %> 有効<br>
            <%= f.radio_button :is_active, false %> 無効
          </div>
          <div class = "col-2 text-center">
            <%= f.submit "更新", class: "btn btn-outline-success w-100 " %>
          </div>
        </div>    
      <% end %>
    </div>
  </div>
</div>