<div class = "container-fluid">
  <div class = "row">
    <div class = "col-10 offset-1 mb-3", style="border-bottom: 2px solid black;">
       <h3>管理一覧画面</h3>
    </div>
  </div>
  <div class = "row">
    <div class = "col-6 col-md-4 col-lg-2 offset-lg-1 mb-3">
      <%= link_to admin_users_path, class: "text-decoration-none" do %>
        <div class = "card dashboard-card w-100 h-100">
          <div class = "card-body h-100 d-flex flex-column align-items-center justify-content-center">
            <i class="fa-solid fa-users fa-3x"></i>
            <span class = "mt-3">ユーザー一覧</span>
          </div>
        </div>
      <% end %>
    </div>
    <div class = "col-6 col-md-4 col-lg-2 mb-3">
      <%= link_to admin_study_records_path, class: "text-decoration-none" do %>
        <div class = "card dashboard-card w-100 h-100">
          <div class = "card-body h-100 d-flex flex-column align-items-center justify-content-center">
            <i class="fa-solid fa-book-open fa-3x"></i>
            <span class = "mt-3">学習記録一覧</span>
          </div>
        </div>
      <% end %>
    </div>
    <div class = "col-6 col-md-4 col-lg-2 mb-3">
      <%= link_to admin_comments_path, class: "text-decoration-none" do %>
        <div class = "card dashboard-card w-100 h-100">
          <div class = "card-body h-100 d-flex flex-column align-items-center justify-content-center">
            <i class="fa-solid fa-comments fa-3x"></i>
            <span class = "mt-3">コメント一覧</span>
          </div>
        </div>
      <% end %>
    </div>
    <div class = "col-6 col-md-4 col-lg-2 mb-3">
      <%= link_to admin_study_categories_path, class: "text-decoration-none" do %>
        <div class = "card dashboard-card w-100 h-100">
          <div class = "card-body h-100 d-flex flex-column align-items-center justify-content-center">
            <i class="fa-solid fa-rectangle-list fa-3x"></i>
            <span class = "mt-3">学習カテゴリ一覧</span>
          </div>
        </div>
      <% end %>
    </div>
    <div class = "col-6 col-md-4 col-lg-2 mb-3">
      <%= link_to admin_stamps_path, class: "text-decoration-none" do %>
        <div class = "card dashboard-card w-100 h-100">
          <div class = "card-body h-100 d-flex flex-column align-items-center justify-content-center">
            <i class="fa-solid fa-icons fa-3x"></i>
            <span class = "mt-3">スタンプ一覧</span>
          </div>
        </div>
      <% end %>
    </div>
    <div class = "col-6 col-md-4 col-lg-2 offset-lg-1 mb-3">
      <%= link_to admin_rooms_path, class: "text-decoration-none" do %>
        <div class = "card dashboard-card w-100 h-100">
          <div class = "card-body h-100 d-flex flex-column align-items-center justify-content-center">
            <i class="fa-solid fa-door-open fa-3x"></i>
            <span class = "mt-3">ルームライブ管理</span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
