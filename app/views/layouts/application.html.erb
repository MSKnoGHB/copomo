<!DOCTYPE html>
<html>
  <head>
    <title>COPOMO</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <% if user_signed_in? %>
      <meta name="current-user-id" content="<%= current_user.id %>">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <script src="https://kit.fontawesome.com/8edf93cddf.js" crossorigin="anonymous"></script>
    <%= stylesheet_pack_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_pack_tag 'application', 'data-turbolinks-track': 'reload' %>
  </head>

  <body class="d-flex flex-column min-vh-100 <%= controller_name %>-<%= action_name %>">
    <header>
      <div class = "container-fluid h-100">
        <div class = "row h-100">
          <div class = "col-4 h-100 px-0 py-0"> 
            <%= link_to public_root_path do %>
              <%= image_tag "copomo_logo_t2.png", style: "height: 100%;" %>
            <% end %>
          </div>
          <div class = "col-8 px-0 py-0 d-flex justify-content-end">
            <nav class="navbar navbar-expand-lg navbar-light w-100 p-0 justify-content-end">
      
              <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
              </button>

              <div class="collapse navbar-collapse h-100 justify-content-end" id="navbarNav">
                <ul class="navbar-nav header-list list-unstyled mb-0 h-100 align-items-center">
                  <% if user_signed_in? %>
                    <li class = "nav-item">
                      <%= link_to "ログアウト", destroy_user_session_path, method: :delete, class: "nav-link" %>
                    </li>
                    <li class = "h-100 nav-item">
                      <%= link_to "マイページ", public_user_path(current_user.id), class: "nav-link" %>
                    </li>
                    <li class = "h-100 nav-item">
                      <%= link_to "学習ルーム", public_rooms_path, class: "nav-link" %>
                    </li>
                    <li class = "h-100 nav-item">
                      <%= link_to "タイムライン",public_study_records_path, class: "nav-link" %>
                    </li>
                  <% else %>
                    <li class = "h-100 nav-item">
                      <%= link_to "新規登録", new_user_registration_path, class: "nav-link" %>
                    </li>
                    <li class = "h-100 nav-item">
                      <%= link_to "ログイン", new_user_session_path, class: "nav-link" %>
                    </li>
                  <% end %>
                  <li class = "h-100 nav-item">
                    <%= link_to "COPOMOとは", public_about_path, class: "nav-link" %>
                  </li>
                </ul>
              </div>
            </nav>
          </div>
        </div>
      </div>
    </header>

    <main class="flex-fill d-flex mt-3">
      <%= yield %>
    </main>

    <footer class="d-flex  align-items-center justify-content-center">
      <p class="m-0">&copy; 2026 COPOMO.</p>
    </footer>

  </body>
</html>
