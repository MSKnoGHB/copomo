<% if user_signed_in? %>
  <div class = "row m-0">
    <%= form_with url: search_path, method: :get do |f| %>
      <div class = "col-12 p-0">
        <%= f.text_field :content, placeholder: "検索ワードを入力", required: true, class: "form-control" %>
        <%= f.select :model, options_for_select({ "ユーザ名" => "user", "学習テーマ" => "study_theme" }) %>
        <%= f.select :method, options_for_select({ "完全一致" => "perfect", "前方一致" => "forward", "後方一致" => "backward", "部分一致" => "partial" }) %>
        <%= f.submit '検索'%>
      </div>
    <% end %>  
  </div>
<% end %> 