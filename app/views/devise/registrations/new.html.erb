<div class="container">
  <div class = "row">
    <div class = "col-12 text-center">
      <% if flash[:notice] %>
        <div class="alert alert-success">
          <%= flash[:notice] %>
        </div>
      <% end %>
    </div>
  </div>
  <div class="row">
    <div class="col-12 text-center">
      <%= image_tag "logo_copomo_type2.png", class: "img-fluid mt-1 mb-1", style: "max-height: 100px;" %>
    </div>
  </div>
  <div class="row">
    <div class="col-12 text-center mt-1 mb-1">
      <h3>アカウント登録</h3>
    </div>
  </div>  
  <div class="row">
    <div class="col-10 offset-1 col-md-8 offset-md-2 col-lg-6 offset-lg-3 card-body p-0 ">
      <div class="card w-100 pt-3 pl-5 pr-5 mx-auto shadow-lg">
        <%= form_with model: @user, url: user_registration_path do |f| %>
          <% if @user.errors.any? %>
            <div class="alert alert-danger">
              <strong><%= @user.errors.count %>件のエラーが発生しました</strong>
              <ul>
                <% @user.errors.full_messages.each do |message| %>
                  <li><%= message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>
          <div class="mb-3">
            <%= f.label :name, "ユーザー名" %>
            <em>(20文字以下)</em><br />
            <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :email, "メールアドレス" %><br />
            <%= f.email_field :email, autocomplete: "email", class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :password, "パスワード" %>
            <% if @minimum_password_length %>
            <em>(<%= @minimum_password_length %> 文字以上)</em>
            <% end %><br />
            <%= f.password_field :password, autocomplete: "new-password", class: "form-control" %>
          </div>
          <div class="mb-3">
            <%= f.label :password_confirmation, "パスワード(確認用)" %><br />
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-control" %>
          </div>
          <div class="actions">
            <%= f.submit "新規登録", class: "btn btn-success btn-lg w-100 mb-2"  %>
          </div>
        <% end %>
        <%= render "devise/shared/links" %>
      </div>
    </div>  
  </div>
</div>